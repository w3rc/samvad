{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/w3rc/samvad/schema/v1.2/agent-card.schema.json",
  "title": "SAMVAD Agent Card",
  "description": "Machine-readable identity card served at GET /.well-known/agent.json by every compliant SAMVAD agent.",
  "type": "object",
  "required": ["id", "name", "version", "description", "url", "protocolVersion", "skills", "publicKeys"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^agent://",
      "description": "Globally unique agent identifier in agent:// URI form.",
      "examples": ["agent://myagent.com"]
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "Human-readable display name."
    },
    "version": {
      "type": "string",
      "description": "Agent software version (semver recommended).",
      "examples": ["1.2.0"]
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Short description of the agent's purpose."
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Base HTTPS URL of the agent.",
      "examples": ["https://myagent.com"]
    },
    "protocolVersion": {
      "type": "string",
      "description": "SAMVAD protocol version this agent implements.",
      "examples": ["1.2"]
    },
    "specializations": {
      "type": "array",
      "items": { "type": "string", "maxLength": 50 },
      "description": "Topic tags describing the agent's domain expertise.",
      "examples": [["code-review", "security-audit"]]
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "model"],
        "properties": {
          "provider": { "type": "string", "examples": ["anthropic", "openai"] },
          "model": { "type": "string", "examples": ["claude-opus-4-6", "gpt-4o"] }
        }
      },
      "description": "LLM(s) used by the agent."
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/SkillDef" },
      "description": "Typed, callable capabilities this agent exposes."
    },
    "publicKeys": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/PublicKey" },
      "description": "Ed25519 public keys used to verify message signatures."
    },
    "auth": {
      "type": "object",
      "properties": {
        "schemes": {
          "type": "array",
          "items": { "type": "string", "enum": ["bearer", "none"] }
        }
      },
      "description": "Authentication schemes accepted by this agent."
    },
    "rateLimit": { "$ref": "#/$defs/RateLimit" },
    "cardTTL": {
      "type": "integer",
      "minimum": 0,
      "description": "Seconds after which receivers should re-fetch this card.",
      "examples": [300]
    },
    "endpoints": {
      "type": "object",
      "properties": {
        "intro":      { "type": "string" },
        "message":    { "type": "string" },
        "task":       { "type": "string" },
        "taskStatus": { "type": "string" },
        "stream":     { "type": "string" },
        "health":     { "type": "string" }
      },
      "description": "Path overrides for standard endpoints (if not using defaults)."
    }
  },
  "$defs": {
    "SkillDef": {
      "type": "object",
      "required": ["id", "name", "description", "inputSchema", "outputSchema", "modes", "trust"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 64,
          "description": "Stable identifier used in message envelopes.",
          "examples": ["review-code"]
        },
        "name": {
          "type": "string",
          "maxLength": 100,
          "description": "Human-readable skill name."
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "inputSchema": {
          "type": "object",
          "description": "JSON Schema for the skill's payload input."
        },
        "outputSchema": {
          "type": "object",
          "description": "JSON Schema for the skill's result output."
        },
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["sync", "async", "stream"] },
          "description": "Communication modes this skill supports."
        },
        "trust": {
          "type": "string",
          "enum": ["public", "authenticated", "trusted-peers"],
          "description": "Access control tier."
        },
        "allowedPeers": {
          "type": "array",
          "items": { "type": "string", "pattern": "^agent://" },
          "description": "Required when trust is 'trusted-peers'. agent:// IDs that may call this skill."
        }
      }
    },
    "PublicKey": {
      "type": "object",
      "required": ["kid", "key", "active"],
      "additionalProperties": false,
      "properties": {
        "kid": {
          "type": "string",
          "description": "Key identifier referenced in message envelopes.",
          "examples": ["key-2"]
        },
        "key": {
          "type": "string",
          "description": "Base64-encoded Ed25519 public key (raw 32-byte key)."
        },
        "active": {
          "type": "boolean",
          "description": "False means the key has been revoked; receivers must reject signatures from inactive keys."
        }
      }
    },
    "RateLimit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requestsPerMinute": {
          "type": "integer",
          "minimum": 1,
          "description": "Global incoming request cap per minute."
        },
        "requestsPerSender": {
          "type": "integer",
          "minimum": 1,
          "description": "Per-sender request cap per minute (sliding window)."
        },
        "tokensPerSenderPerDay": {
          "type": "integer",
          "minimum": 1,
          "description": "Per-sender daily LLM token budget. Resets at UTC midnight."
        }
      }
    }
  }
}
