{
  "name": "@samvad-protocol/sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for SAMVAD — Secure Agent Messaging, Verification And Discovery (The Open Sovereign Agent Dialogue Protocol)",
  "license": "Apache-2.0",
  "author": "The SAMVAD Authors",
  "homepage": "https://github.com/w3rc/samvad#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w3rc/samvad.git",
    "directory": "packages/sdk-typescript"
  },
  "bugs": {
    "url": "https://github.com/w3rc/samvad/issues"
  },
  "keywords": [
    "agent",
    "a2a",
    "protocol",
    "samvad",
    "ai",
    "llm",
    "multi-agent",
    "ed25519",
    "signing",
    "sdk"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && cp ../../LICENSE ../../NOTICE ../../README.md .",
    "postpublish": "rm -f LICENSE NOTICE README.md",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "fastify": "^5.0.0",
    "jose": "^5.9.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
